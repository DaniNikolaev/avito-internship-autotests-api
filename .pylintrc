[MESSAGES CONTROL]
disable=
    missing-docstring,
    no-name-in-module,
    import-error,
    too-few-public-methods,
    no-member,
    broad-exception-caught,
    redefined-outer-name,
    logging-fstring-interpolation,
    unexpected-keyword-arg
[FORMAT]
max-line-length=120
[BASIC]
ignore=
    .idea,
    .pytest_cache
    .venv,
    __pycache__,
    venv